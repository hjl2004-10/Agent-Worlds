<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>夸父</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Consolas', monospace;
            background: #1a1a2e;
            color: #eee;
            min-height: 100vh;
            padding: 20px;
        }
        h1 {
            text-align: center;
            color: #0f0;
            margin-bottom: 20px;
        }
        .container {
            display: flex;
            gap: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }
        .panel {
            background: #16213e;
            border: 1px solid #0f0;
            border-radius: 8px;
            padding: 15px;
            flex: 1;
        }
        .panel h2 {
            color: #0f0;
            border-bottom: 1px solid #0f0;
            padding-bottom: 10px;
            margin-bottom: 15px;
        }
        #map {
            width: 100%;
            height: 400px;
            background: #0a0a1a;
            border: 1px solid #333;
            position: relative;
            border-radius: 4px;
        }
        .npc-dot {
            position: absolute;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .npc-dot.talking { animation: pulse 0.5s infinite; }
        .npc-dot.god-selected {
            box-shadow: 0 0 10px #fff, 0 0 20px #fff;
            width: 16px;
            height: 16px;
        }
        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 5px #fff; }
            50% { box-shadow: 0 0 20px #fff; }
        }
        .npc-label {
            position: absolute;
            transform: translate(-50%, -150%);
            font-size: 12px;
            white-space: nowrap;
        }
        .npc-list { list-style: none; }
        .npc-list li {
            padding: 10px;
            margin: 5px 0;
            background: #0a0a1a;
            border-radius: 4px;
            border-left: 3px solid #0f0;
            cursor: pointer;
        }
        .npc-list li:hover { background: #1a1a3a; }
        .npc-list li.talking { border-left-color: #ff0; }
        .npc-list li.exhausted { border-left-color: #f00; opacity: 0.6; }
        .npc-list li.god-selected { border-left-color: #fff; background: #2a2a4a; }
        .status-bar {
            display: flex;
            justify-content: space-between;
            padding: 10px;
            background: #0a0a1a;
            border-radius: 4px;
            margin-bottom: 20px;
        }
        .status-item { color: #0f0; }
        .god-mode-panel {
            background: #16213e;
            border: 1px solid #ff0;
            border-radius: 8px;
            padding: 15px;
            margin-top: 20px;
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
        }
        .god-mode-panel h2 { color: #ff0; border-bottom: 1px solid #ff0; }
        .god-controls {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-top: 15px;
        }
        .god-controls button {
            background: #333;
            color: #fff;
            border: 1px solid #ff0;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            font-family: inherit;
        }
        .god-controls button:hover { background: #444; }
        .god-controls button:disabled { opacity: 0.5; cursor: not-allowed; }
        .arrow-keys {
            display: grid;
            grid-template-columns: repeat(3, 40px);
            grid-template-rows: repeat(2, 40px);
            gap: 5px;
        }
        .arrow-keys button {
            width: 40px;
            height: 40px;
            padding: 0;
            font-size: 18px;
        }
        .arrow-keys .up { grid-column: 2; }
        .arrow-keys .left { grid-column: 1; grid-row: 2; }
        .arrow-keys .down { grid-column: 2; grid-row: 2; }
        .arrow-keys .right { grid-column: 3; grid-row: 2; }
        .god-status {
            color: #ff0;
            font-size: 14px;
        }
        .hint {
            color: #888;
            font-size: 12px;
            margin-top: 10px;
        }
        .player-panel {
            background: #16213e;
            border: 1px solid #0ff;
            border-radius: 8px;
            padding: 15px;
            margin-top: 20px;
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
        }
        .player-panel h2 { color: #0ff; border-bottom: 1px solid #0ff; }
        .player-input-area {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }
        .player-input-area input {
            flex: 1;
            background: #0a0a1a;
            border: 1px solid #0ff;
            color: #fff;
            padding: 10px;
            border-radius: 4px;
            font-family: inherit;
        }
        .player-input-area button {
            background: #0ff;
            color: #000;
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
            font-family: inherit;
            font-weight: bold;
        }
        .player-input-area button:hover { background: #0aa; }
        .player-input-area button:disabled { background: #555; cursor: not-allowed; }
        .player-input-area button.end-btn {
            background: #f44;
            color: #fff;
            border: none;
        }
        .player-input-area button.end-btn:hover { background: #c22; }
        .conversation-status {
            margin-top: 10px;
            padding: 10px;
            background: #0a0a1a;
            border-radius: 4px;
        }
        .conversation-status.waiting { border-left: 3px solid #0ff; }
        .conversation-status.idle { border-left: 3px solid #888; }
        .npc-dot.player {
            width: 16px;
            height: 16px;
            border: 2px solid #fff;
        }
        /* 任务管理面板样式 */
        .task-panel {
            background: #16213e;
            border: 1px solid #f0f;
            border-radius: 8px;
            padding: 15px;
            margin-top: 20px;
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
        }
        .task-panel h2 { color: #f0f; border-bottom: 1px solid #f0f; }
        .task-controls {
            display: grid;
            grid-template-columns: 1fr 2fr 1fr;
            gap: 10px;
            margin-top: 15px;
            align-items: end;
        }
        .task-controls select,
        .task-controls input,
        .task-controls textarea {
            background: #0a0a1a;
            border: 1px solid #f0f;
            color: #fff;
            padding: 10px;
            border-radius: 4px;
            font-family: inherit;
        }
        .task-controls select { cursor: pointer; }
        .task-controls textarea {
            resize: vertical;
            min-height: 60px;
        }
        .task-btn-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }
        .task-btn-group button {
            background: #f0f;
            color: #000;
            border: none;
            padding: 10px;
            border-radius: 4px;
            cursor: pointer;
            font-family: inherit;
            font-weight: bold;
        }
        .task-btn-group button:hover { background: #c0c; }
        .task-btn-group button:disabled { background: #555; cursor: not-allowed; }
        .task-btn-group button.secondary {
            background: #333;
            color: #f0f;
            border: 1px solid #f0f;
        }
        .task-btn-group button.secondary:hover { background: #444; }
        .task-list {
            margin-top: 15px;
        }
        .task-item {
            background: #0a0a1a;
            border-left: 3px solid #f0f;
            padding: 10px;
            margin-bottom: 8px;
            border-radius: 4px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .task-item.done { border-left-color: #888; opacity: 0.7; }
        .task-info { flex: 1; }
        .task-info .status-tag {
            display: inline-block;
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 11px;
            margin-right: 8px;
        }
        .task-info .status-tag.pending { background: #f0f; color: #000; }
        .task-info .status-tag.done { background: #888; color: #fff; }
        .task-info .source { color: #888; font-size: 12px; }
        .task-info .tool-hint { color: #0ff; font-size: 11px; margin-top: 4px; }
        .task-actions { display: flex; gap: 5px; }
        .task-actions button {
            background: #333;
            color: #fff;
            border: 1px solid #666;
            padding: 5px 10px;
            border-radius: 3px;
            cursor: pointer;
            font-size: 12px;
        }
        .task-actions button:hover { background: #444; }
        .task-actions button.complete-btn { border-color: #0f0; color: #0f0; }
        .task-actions button.delete-btn { border-color: #f44; color: #f44; }
        .task-message {
            margin-top: 10px;
            padding: 8px;
            border-radius: 4px;
            font-size: 13px;
        }
        .task-message.success { background: #0a2a0a; border: 1px solid #0f0; color: #0f0; }
        .task-message.error { background: #2a0a0a; border: 1px solid #f44; color: #f44; }
    </style>
</head>
<body>
    <h1>AI_OS v2.0 Monitor</h1>

    <div class="status-bar">
        <span class="status-item">Tick: <span id="tick">0</span></span>
        <span class="status-item">NPCs: <span id="npc-count">0</span></span>
        <span class="status-item">状态: <span id="status">运行中</span></span>
    </div>

    <div class="container">
        <div class="panel">
            <h2>地图视图</h2>
            <div id="map"></div>
        </div>
        <div class="panel">
            <h2>NPC列表</h2>
            <ul class="npc-list" id="npc-list"></ul>
        </div>
    </div>

    <div class="god-mode-panel">
        <h2>上帝模式</h2>
        <div class="god-controls">
            <div class="god-status">
                当前控制: <strong id="god-selected">无</strong>
            </div>
            <button id="btn-deselect" onclick="godDeselect()">取消控制</button>
            <div class="arrow-keys">
                <button class="up" onmousedown="godMove('up')" onmouseup="godStop()" onmouseleave="godStop()">↑</button>
                <button class="left" onmousedown="godMove('left')" onmouseup="godStop()" onmouseleave="godStop()">←</button>
                <button class="down" onmousedown="godMove('down')" onmouseup="godStop()" onmouseleave="godStop()">↓</button>
                <button class="right" onmousedown="godMove('right')" onmouseup="godStop()" onmouseleave="godStop()">→</button>
            </div>
        </div>
        <p class="hint">点击 NPC 或列表项选中，使用方向键或按钮控制移动 (按住持续移动)</p>
    </div>

    <div class="player-panel">
        <h2>玩家输入</h2>
        <div class="conversation-status" id="conv-status">
            等待对话...
        </div>
        <div class="player-input-area">
            <input type="text" id="player-text" placeholder="输入对话内容..." disabled>
            <button id="send-btn" onclick="sendPlayerInput()" disabled>发送</button>
            <button id="end-btn" class="end-btn" onclick="endConversation()" disabled>结束对话</button>
        </div>
        <p class="hint">当玩家进入对话时，输入框会自动启用</p>
    </div>

    <div class="task-panel">
        <h2>任务管理</h2>
        <div class="task-controls">
            <div>
                <label style="color:#888;font-size:12px;">目标 NPC</label><br>
                <select id="task-target" onchange="loadTaskList()">
                    <option value="">-- 选择 NPC --</option>
                </select>
            </div>
            <div style="display:flex;flex-direction:column;gap:5px;">
                <div>
                    <label style="color:#888;font-size:12px;">任务描述</label><br>
                    <input type="text" id="task-hint" placeholder="例: 查看 Bob 留给你的信" style="width:100%;">
                </div>
                <div style="display:flex;gap:5px;align-items:flex-end;">
                    <div style="flex:1;">
                        <label style="color:#888;font-size:12px;">工具选择 (可选)</label><br>
                        <select id="task-tool-select" onchange="onToolSelect()" style="width:100%;">
                            <option value="">-- 不使用工具 --</option>
                        </select>
                    </div>
                    <div id="tool-param-area" style="flex:2;display:none;">
                        <label style="color:#888;font-size:12px;" id="tool-param-label">参数</label><br>
                        <input type="text" id="task-tool-param" placeholder="例: letter.txt" style="width:100%;">
                    </div>
                </div>
                <div id="tool-param-hint" style="color:#666;font-size:11px;display:none;"></div>
            </div>
            <div class="task-btn-group">
                <button onclick="assignTask()">下放任务</button>
                <button class="secondary" onclick="refreshTaskList()">刷新列表</button>
            </div>
        </div>
        <div id="task-message" class="task-message" style="display:none;"></div>
        <div class="task-list" id="task-list">
            <p style="color:#888;text-align:center;padding:20px;">选择 NPC 查看任务列表</p>
        </div>
        <p class="hint">任务描述支持模糊匹配，删除/完成时会匹配包含该关键词的所有任务</p>
    </div>

    <script>
        const MAP_WIDTH = 100;
        const MAP_HEIGHT = 100;
        const colors = ['#0f0', '#0ff', '#f0f', '#ff0', '#f00'];
        let selectedNpc = null;
        let isWaitingForInput = false;

        async function fetchData() {
            try {
                const [statusRes, npcsRes, godRes, convRes] = await Promise.all([
                    fetch('/api/status'),
                    fetch('/api/npcs'),
                    fetch('/api/god/status'),
                    fetch('/api/conversation/state')
                ]);
                const status = await statusRes.json();
                const npcs = await npcsRes.json();
                const godStatus = await godRes.json();
                const convState = await convRes.json();

                document.getElementById('tick').textContent = status.tick;
                document.getElementById('npc-count').textContent = status.npc_count;

                selectedNpc = godStatus.selected_npc;
                document.getElementById('god-selected').textContent = selectedNpc || '无';

                // 更新对话状态
                updateConversationUI(convState);

                renderMap(npcs);
                renderList(npcs);
            } catch (e) {
                document.getElementById('status').textContent = '连接失败';
            }
        }

        function updateConversationUI(convState) {
            const statusEl = document.getElementById('conv-status');
            const inputEl = document.getElementById('player-text');
            const btnEl = document.getElementById('send-btn');
            const endBtnEl = document.getElementById('end-btn');

            if (convState.active && convState.waiting) {
                statusEl.className = 'conversation-status waiting';
                statusEl.innerHTML = `<strong>正在对话:</strong> ${convState.speaker} → ${convState.listener}<br>等待玩家输入...`;
                inputEl.disabled = false;
                btnEl.disabled = false;
                endBtnEl.disabled = false;
                isWaitingForInput = true;
                inputEl.focus();
            } else if (convState.active) {
                statusEl.className = 'conversation-status waiting';
                statusEl.innerHTML = `<strong>正在对话:</strong> ${convState.speaker} → ${convState.listener}<br>处理中...`;
                inputEl.disabled = true;
                btnEl.disabled = true;
                endBtnEl.disabled = false;
                isWaitingForInput = false;
            } else {
                statusEl.className = 'conversation-status idle';
                statusEl.textContent = '等待对话...';
                inputEl.disabled = true;
                btnEl.disabled = true;
                endBtnEl.disabled = true;
                isWaitingForInput = false;
            }
        }

        async function endConversation() {
            await fetch('/api/conversation/end', { method: 'POST' });
        }

        async function sendPlayerInput() {
            const input = document.getElementById('player-text');
            const text = input.value.trim();
            if (!text || !isWaitingForInput) return;

            const convRes = await fetch('/api/conversation/state');
            const convState = await convRes.json();

            if (convState.speaker) {
                await fetch('/api/player/input', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        player_name: convState.speaker,
                        text: text
                    })
                });
                input.value = '';
            }
        }

        function renderMap(npcs) {
            const map = document.getElementById('map');
            const mapW = map.offsetWidth;
            const mapH = map.offsetHeight;

            // 清除旧的
            map.querySelectorAll('.npc-dot, .npc-label').forEach(el => el.remove());

            npcs.forEach((npc, i) => {
                const x = (npc.x / MAP_WIDTH) * mapW;
                const y = (npc.y / MAP_HEIGHT) * mapH;
                const color = colors[i % colors.length];

                // 点
                const dot = document.createElement('div');
                let dotClass = 'npc-dot';
                if (npc.is_player) dotClass += ' player';
                if (npc.is_talking) dotClass += ' talking';
                if (npc.god_controlled) dotClass += ' god-selected';
                dot.className = dotClass;
                dot.style.left = x + 'px';
                dot.style.top = y + 'px';
                dot.style.background = color;
                dot.onclick = () => godSelect(npc.name);
                map.appendChild(dot);

                // 标签
                const label = document.createElement('div');
                label.className = 'npc-label';
                label.style.left = x + 'px';
                label.style.top = y + 'px';
                label.style.color = color;
                let labelText = npc.name;
                if (npc.god_controlled) labelText += ' [控制中]';
                if (npc.is_player) labelText += ' [玩家]';
                label.textContent = labelText;
                map.appendChild(label);
            });
        }

        function renderList(npcs) {
            const list = document.getElementById('npc-list');
            list.innerHTML = npcs.map((npc, i) => {
                let cls = '';
                if (npc.god_controlled) cls = 'god-selected';
                else if (npc.is_talking) cls = 'talking';
                else if (npc.initiative < 0) cls = 'exhausted';

                const playerTag = npc.is_player ? '<span style="color:#0ff"> [玩家]</span>' : '';
                const godTag = npc.god_controlled ? '<span style="color:#ff0"> [控制中]</span>' : '';

                return `<li class="${cls}" onclick="godSelect('${npc.name}')">
                    <strong style="color:${colors[i % colors.length]}">${npc.name}</strong>
                    ${playerTag}${godTag}<br>
                    位置: (${npc.x.toFixed(1)}, ${npc.y.toFixed(1)})<br>
                    主动值: ${npc.initiative}<br>
                    ${npc.ban_target ? '冷却中: ' + npc.ban_target : ''}
                </li>`;
            }).join('');
        }

        async function godSelect(name) {
            await fetch(`/api/god/select/${name}`, { method: 'POST' });
            fetchData();
        }

        async function godDeselect() {
            await fetch('/api/god/deselect', { method: 'POST' });
            fetchData();
        }

        async function godMove(direction) {
            if (!selectedNpc) return;
            await fetch(`/api/god/move/${direction}`, { method: 'POST' });
        }

        async function godStop() {
            await fetch('/api/god/stop', { method: 'POST' });
        }

        // 跟踪当前按下的方向键
        let currentDirection = null;

        // 键盘控制 - 按下开始移动
        document.addEventListener('keydown', (e) => {
            if (!selectedNpc) return;

            const keyMap = {
                'ArrowUp': 'up',
                'ArrowDown': 'down',
                'ArrowLeft': 'left',
                'ArrowRight': 'right',
                'w': 'up',
                's': 'down',
                'a': 'left',
                'd': 'right'
            };

            if (keyMap[e.key] && keyMap[e.key] !== currentDirection) {
                e.preventDefault();
                currentDirection = keyMap[e.key];
                godMove(keyMap[e.key]);
            }

            // ESC 取消选择
            if (e.key === 'Escape') {
                godDeselect();
            }
        });

        // 键盘控制 - 松开停止移动
        document.addEventListener('keyup', (e) => {
            const keyMap = {
                'ArrowUp': 'up',
                'ArrowDown': 'down',
                'ArrowLeft': 'left',
                'ArrowRight': 'right',
                'w': 'up',
                's': 'down',
                'a': 'left',
                'd': 'right'
            };

            if (keyMap[e.key] === currentDirection) {
                currentDirection = null;
                godStop();
            }
        });

        // 回车发送玩家输入
        document.getElementById('player-text').addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendPlayerInput();
            }
        });

        // 每500ms刷新
        setInterval(fetchData, 500);
        fetchData();
        loadTools();  // 加载工具列表

        // ================== 任务管理功能 ==================
        let npcListCache = [];
        let toolsCache = {};

        // 加载工具列表
        async function loadTools() {
            try {
                const res = await fetch('/api/tools');
                const data = await res.json();
                if (data.status === 'ok') {
                    toolsCache = data.tools;
                    renderToolSelect();
                }
            } catch (e) {
                console.error('加载工具列表失败', e);
            }
        }

        // 渲染工具下拉选择器
        function renderToolSelect() {
            const select = document.getElementById('task-tool-select');
            select.innerHTML = '<option value="">-- 不使用工具 --</option>';

            const toolNames = {
                'read_file': '读取文件',
                'write_file': '写入文件',
                'edit_text': '编辑文件'
            };

            for (const [name, config] of Object.entries(toolsCache)) {
                const option = document.createElement('option');
                option.value = name;
                option.textContent = toolNames[name] || name;
                select.appendChild(option);
            }
        }

        // 工具选择变化
        function onToolSelect() {
            const select = document.getElementById('task-tool-select');
            const paramArea = document.getElementById('tool-param-area');
            const paramLabel = document.getElementById('tool-param-label');
            const paramHint = document.getElementById('tool-param-hint');
            const paramInput = document.getElementById('task-tool-param');

            const toolName = select.value;

            if (!toolName) {
                paramArea.style.display = 'none';
                paramHint.style.display = 'none';
                return;
            }

            const tool = toolsCache[toolName];
            if (!tool) return;

            // 显示参数输入
            paramArea.style.display = 'block';

            // 根据工具类型设置参数提示
            if (toolName === 'read_file') {
                paramLabel.textContent = '文件路径';
                paramInput.placeholder = '例: letter.txt';
                paramHint.textContent = '工具: read_file - ' + tool.description;
            } else if (toolName === 'write_file') {
                paramLabel.textContent = '文件路径';
                paramInput.placeholder = '例: note.txt';
                paramHint.textContent = '工具: write_file - ' + tool.description + ' (内容由 NPC 自行决定)';
            } else if (toolName === 'edit_text') {
                paramLabel.textContent = '文件路径';
                paramInput.placeholder = '例: story.txt';
                paramHint.textContent = '工具: edit_text - ' + tool.description;
            }

            paramHint.style.display = 'block';
        }

        // 构建工具指引字符串
        function buildToolHint() {
            const toolName = document.getElementById('task-tool-select').value;
            if (!toolName) return '';

            const param = document.getElementById('task-tool-param').value.trim();
            if (!param) return '';

            return `${toolName}: path=${param}`;
        }

        // 更新 NPC 下拉选择器
        function updateTaskTargetSelect(npcs) {
            npcListCache = npcs;
            const select = document.getElementById('task-target');
            const currentValue = select.value;
            select.innerHTML = '<option value="">-- 选择 NPC --</option>';
            npcs.forEach(npc => {
                const option = document.createElement('option');
                option.value = npc.name;
                option.textContent = npc.name;
                select.appendChild(option);
            });
            if (currentValue && npcs.some(n => n.name === currentValue)) {
                select.value = currentValue;
            }
        }

        // 显示任务消息
        function showTaskMessage(msg, isError = false) {
            const el = document.getElementById('task-message');
            el.textContent = msg;
            el.className = 'task-message ' + (isError ? 'error' : 'success');
            el.style.display = 'block';
            setTimeout(() => { el.style.display = 'none'; }, 3000);
        }

        // 下放任务
        async function assignTask() {
            const target = document.getElementById('task-target').value;
            const hint = document.getElementById('task-hint').value.trim();
            const toolHint = buildToolHint();

            if (!target) {
                showTaskMessage('请选择目标 NPC', true);
                return;
            }
            if (!hint) {
                showTaskMessage('请输入任务描述', true);
                return;
            }

            const body = { target, hint };
            if (toolHint) body.tool_hint = toolHint;

            try {
                const res = await fetch('/api/tasks/assign', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                const data = await res.json();
                if (data.status === 'ok') {
                    showTaskMessage(`任务已下放给 ${target}`);
                    document.getElementById('task-hint').value = '';
                    document.getElementById('task-tool-select').value = '';
                    document.getElementById('task-tool-param').value = '';
                    document.getElementById('tool-param-area').style.display = 'none';
                    document.getElementById('tool-param-hint').style.display = 'none';
                    loadTaskList();
                } else {
                    showTaskMessage(data.message || '下放失败', true);
                }
            } catch (e) {
                showTaskMessage('网络错误', true);
            }
        }

        // 加载任务列表
        async function loadTaskList() {
            const target = document.getElementById('task-target').value;
            const listEl = document.getElementById('task-list');

            if (!target) {
                listEl.innerHTML = '<p style="color:#888;text-align:center;padding:20px;">选择 NPC 查看任务列表</p>';
                return;
            }

            try {
                const res = await fetch(`/api/tasks/${encodeURIComponent(target)}`);
                const data = await res.json();
                if (data.status === 'ok') {
                    renderTaskList(data.tasks);
                } else {
                    listEl.innerHTML = `<p style="color:#f44;text-align:center;padding:20px;">${data.message}</p>`;
                }
            } catch (e) {
                listEl.innerHTML = '<p style="color:#f44;text-align:center;padding:20px;">加载失败</p>';
            }
        }

        // 渲染任务列表
        function renderTaskList(tasks) {
            const listEl = document.getElementById('task-list');
            if (!tasks || tasks.length === 0) {
                listEl.innerHTML = '<p style="color:#888;text-align:center;padding:20px;">暂无任务</p>';
                return;
            }

            listEl.innerHTML = tasks.map((task, idx) => {
                const statusClass = task.status === 'done' ? 'done' : '';
                const statusText = task.status === 'done' ? '已完成' : '待办';
                const statusTagClass = task.status === 'done' ? 'done' : 'pending';

                const completeBtn = task.status !== 'done'
                    ? `<button class="complete-btn" onclick="completeTask('${encodeURIComponent(task.hint)}')">完成</button>`
                    : '';

                return `
                    <div class="task-item ${statusClass}">
                        <div class="task-info">
                            <span class="status-tag ${statusTagClass}">${statusText}</span>
                            <span>${escapeHtml(task.hint)}</span>
                            <div class="source">来源: ${escapeHtml(task.source)}</div>
                            ${task.tool_hint ? `<div class="tool-hint">工具: ${escapeHtml(task.tool_hint)}</div>` : ''}
                        </div>
                        <div class="task-actions">
                            ${completeBtn}
                            <button class="delete-btn" onclick="deleteTask('${encodeURIComponent(task.hint)}')">删除</button>
                        </div>
                    </div>
                `;
            }).join('');
        }

        // HTML 转义
        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // 标记任务完成
        async function completeTask(hintEncoded) {
            const target = document.getElementById('task-target').value;
            const hint = decodeURIComponent(hintEncoded);

            // 提取关键词用于模糊匹配 (取前几个字符)
            const keyword = hint.substring(0, 10);

            try {
                const res = await fetch(`/api/tasks/${encodeURIComponent(target)}/complete`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ hint: keyword })
                });
                const data = await res.json();
                if (data.status === 'ok') {
                    showTaskMessage(`已标记 ${data.completed} 个任务为完成`);
                    loadTaskList();
                } else {
                    showTaskMessage(data.message || '操作失败', true);
                }
            } catch (e) {
                showTaskMessage('网络错误', true);
            }
        }

        // 删除任务
        async function deleteTask(hintEncoded) {
            const target = document.getElementById('task-target').value;
            const hint = decodeURIComponent(hintEncoded);

            // 提取关键词用于模糊匹配
            const keyword = hint.substring(0, 10);

            if (!confirm(`确定删除包含"${keyword}"的任务吗？`)) return;

            try {
                const res = await fetch(`/api/tasks/${encodeURIComponent(target)}`, {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ hint: keyword })
                });
                const data = await res.json();
                if (data.status === 'ok') {
                    showTaskMessage(`已删除 ${data.deleted} 个任务`);
                    loadTaskList();
                } else {
                    showTaskMessage(data.message || '操作失败', true);
                }
            } catch (e) {
                showTaskMessage('网络错误', true);
            }
        }

        // 刷新任务列表
        function refreshTaskList() {
            loadTaskList();
        }

        // 监听 NPC 列表更新
        const originalRenderList = renderList;
        renderList = function(npcs) {
            originalRenderList(npcs);
            updateTaskTargetSelect(npcs);
        };
    </script>
</body>
</html>
